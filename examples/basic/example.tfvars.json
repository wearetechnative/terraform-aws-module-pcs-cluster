{
  "aws_region": "eu-north-1",
  "cluster": {
    "cluster_name": "example-pcs",
    "pcs_scheduler_version": "25.05",
    "pcs_size": "SMALL",
    "login_node_instance_type": "t3.small",
    "cluster_setup": {
      "testqueue1": {
        "computegroup1": {
          "instance_type": "c5.large",
          "min_instance_count": 0,
          "max_instance_count": 5,
          "launch_template": "compute"
        }
      }
    }
  },
  "amis": {
    "compute": "ami-0123456789abcdef0",
    "login": "ami-0123456789abcdef0"
  },
  "bootstrap_scripts": {
    "compute": "#!/bin/bash\necho compute bootstrap\n",
    "login": "#!/bin/bash\necho login bootstrap\n"
  },
  "filesystems": {
    "efs": {
      "id": "fs-0123456789abcdef0"
    },
    "lustre": {
      "id": "fs-0fedcba9876543210",
      "dns_name": "fs-0fedcba9876543210.fsx.eu-north-1.amazonaws.com",
      "mount_name": "abc123",
      "writable_paths": [
        "/data",
        "/output"
      ]
    }
  },
  "networking": {
    "cluster_subnet_ids": [
      "subnet-0123456789abcdef0"
    ],
    "security_group_ids": [
      "sg-0123456789abcdef0"
    ],
    "node_group_subnet_ids": {
      "public": [
        "subnet-0123456789abcdef0"
      ],
      "private": [
        "subnet-0fedcba9876543210"
      ]
    }
  },
  "iam_instance_profile_arn": "arn:aws:iam::123456789012:instance-profile/AWSPCS-example",
  "key_name": "example"
}
